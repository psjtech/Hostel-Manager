<div class="breadcrumb mb-2">
  <a href="/">Dashboard</a> <span class="separator">/</span>
  <a href="/complaints">Complaints</a> <span class="separator">/</span>
  <%= complaint.title %>
</div>

<div class="card mb-3">
  <div class="card-header">
    <h2>📋 <%= complaint.title %></h2>
    <div class="btn-group">
      <span class="badge priority-<%= complaint.priority %>" style="font-size:0.8rem;padding:6px 14px;"><%= complaint.priority %> priority</span>
      <span class="badge status-<%= complaint.status %>" style="font-size:0.8rem;padding:6px 14px;"><%= complaint.status %></span>
    </div>
  </div>
  <div class="card-body">
    <div class="detail-grid">
      <div class="detail-item">
        <span class="detail-label">Student</span>
        <span class="detail-value">
          <a href="/students/<%= complaint.studentId._id %>"><%= complaint.studentId.name %></a>
          <span class="badge badge-primary" style="margin-left:6px;"><%= complaint.studentId.studentId %></span>
        </span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Hostel</span>
        <span class="detail-value"><%= complaint.hostelId ? complaint.hostelId.name : 'N/A' %></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Room</span>
        <span class="detail-value"><%= complaint.roomId ? complaint.roomId.roomNumber : 'N/A' %></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Category</span>
        <span class="detail-value"><span class="badge badge-gray"><%= complaint.category %></span></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Raised On</span>
        <span class="detail-value"><%= new Date(complaint.raisedOn).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Resolved On</span>
        <span class="detail-value"><%= complaint.resolvedOn ? new Date(complaint.resolvedOn).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) : 'Not yet' %></span>
      </div>
    </div>

    <div class="mt-3">
      <h3 class="section-title">Description</h3>
      <p style="color:var(--gray-700);line-height:1.7;background:var(--gray-50);padding:16px;border-radius:var(--radius);"><%= complaint.description %></p>
    </div>

    <% if (complaint.adminRemarks) { %>
      <div class="mt-3">
        <h3 class="section-title">Admin Remarks</h3>
        <p style="color:var(--gray-700);line-height:1.7;background:var(--accent-blue-light);padding:16px;border-radius:var(--radius);"><%= complaint.adminRemarks %></p>
      </div>
    <% } %>
  </div>
</div>

<!-- Update Status -->
<div class="card" style="max-width:600px;">
  <div class="card-header">
    <h2>⚙️ Update Complaint Status</h2>
  </div>
  <div class="card-body">
    <form action="/complaints/<%= complaint._id %>/status" method="POST">
      <div class="form-group">
        <label class="form-label" for="status">New Status *</label>
        <select class="form-control" id="status" name="status" required>
          <option value="open" <%= complaint.status === 'open' ? 'selected' : '' %>>Open</option>
          <option value="in-progress" <%= complaint.status === 'in-progress' ? 'selected' : '' %>>In Progress</option>
          <option value="resolved" <%= complaint.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
          <option value="closed" <%= complaint.status === 'closed' ? 'selected' : '' %>>Closed</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label" for="adminRemarks">Admin Remarks</label>
        <textarea class="form-control" id="adminRemarks" name="adminRemarks" placeholder="Add a note about this complaint..."><%= complaint.adminRemarks %></textarea>
      </div>
      <div class="btn-group mt-2">
        <button type="submit" class="btn btn-primary">Update Status</button>
        <form action="/complaints/<%= complaint._id %>/delete" method="POST" class="delete-form" style="display:inline;">
          <button type="submit" class="btn btn-danger">🗑️ Delete Complaint</button>
        </form>
      </div>
    </form>
  </div>
</div>
